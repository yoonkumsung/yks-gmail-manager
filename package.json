{
  "name": "yks-gmail-manager",
  "version": "2.0.0",
  "description": "Gmail 뉴스레터 다이제스트 시스템 (OpenRouter DeepSeek V4 Pro + GitHub Actions)",
  "type": "commonjs",
  "scripts": {
    "auth": "node scripts/auth.js",
    "refresh": "node scripts/refresh_token.js",
    "html2text": "node scripts/html_to_text.js",
    "report": "node scripts/generate_html.js",
    "digest": "node scripts/orchestrator.js",
    "setup": "node scripts/setup/server.js",
    "test": "node tests/test_runner.js",
    "test:live": "node tests/test_runner.js --live",
    "test:unit": "node tests/test_runner.js agent_runner html_to_text orchestrator",
    "test:e2e": "node tests/test_runner.js e2e",
    "test:coverage": "nyc --reporter=text --reporter=html --reporter=json-summary --include=scripts/**/*.js --exclude=scripts/setup/public/** --exclude=tests/** node tests/test_runner.js",
    "test:digest": "node scripts/orchestrator.js --mode custom --date 2026-01-30 --labels IT",
    "validate:skills": "node scripts/validate_skills.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "googleapis": "^171.0.0",
    "node-fetch": "^3.3.2"
  },
  "private": true,
  "devDependencies": {
    "jsdom": "^29.1.1",
    "nyc": "^18.0.0"
  }
}
