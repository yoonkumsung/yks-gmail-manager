{
  "schema_version": "2.0",

  "llm": {
    "tier": "mixed",

    "providers": {
      "google": {
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai",
        "envKey": "GOOGLE_AI_API_KEY",
        "metadataUrl": null,
        "tier": "free"
      },
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "envKey": "OPENROUTER_API_KEY",
        "metadataUrl": "https://openrouter.ai/api/v1/models",
        "tier": "paid"
      }
    },

    "models": {
      "extract": {
        "primary": { "provider": "openrouter", "model": "deepseek/deepseek-v3.2" },
        "fallback": { "provider": "google", "model": "gemini-3-flash-preview" }
      },
      "reasoning": {
        "primary": { "provider": "openrouter", "model": "deepseek/deepseek-v3.2" },
        "fallback": { "provider": "google", "model": "gemini-3-flash-preview" }
      },
      "vision": { "provider": "openrouter", "model": "nvidia/nemotron-nano-12b-v2-vl:free" }
    },

    "free_limits": {
      "daily_requests": 1400,
      "requests_per_minute": 10
    }
  },

  "gmail": {
    "user_id": "me",
    "max_results_per_query": 100
  },
  "processing": {
    "summary_length": {
      "min": 200,
      "max": 500
    },
    "longform_threshold_lines": 100,
    "longform_threshold_chars": 3000,
    "cluster_max_size": 10,
    "cluster_min_similarity": 0.6
  },
  "output": {
    "root": "./output",
    "timezone": "Asia/Seoul"
  },
  "context_management": {
    "max_items_per_batch": 20,
    "use_subagent_threshold": 50
  },
  "translation": {
    "target_language": "ko",
    "translate_english": true,
    "preserve_proper_nouns": true,
    "proper_noun_format": "한글(원어)"
  }
}
